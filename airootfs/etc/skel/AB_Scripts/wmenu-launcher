#!/bin/bash
# wmenu launcher with Seafront-Storm theme colors

# Seafront-Storm colors (from labwc theme)
BG_NORMAL="#0F1419"      # main background
FG_NORMAL="#F0F0F0"      # light text
BG_SELECTED="#6BB3E5"    # sky blue selection
FG_SELECTED="#0A0A0A"    # dark text on selection

# Launch wmenu with Storm theme
wmenu-run \
	-N "$BG_NORMAL" \
	-n "$FG_NORMAL" \
	-M "$BG_NORMAL" \
	-m "$FG_NORMAL" \
	-S "$BG_SELECTED" \
	-s "$FG_SELECTED" \
	-p " " \
	"$@"
